{
  "name": "aseguradora-api",
  "version": "1.0.0",
  "description": "API REST para sistema de aseguradora de vehículos",
  "main": "dist/index.js",
  "scripts": {
    "dev": "nodemon src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
